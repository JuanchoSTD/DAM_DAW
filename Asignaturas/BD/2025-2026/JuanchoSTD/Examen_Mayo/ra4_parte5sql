-- ej 5.2

UPDATE emision e1
SET
    e1.precio = ( e1.precio + 1.5 )
WHERE
    e1.id_pelicula IN (
        SELECT
            e.id_pelicula
        FROM
                 emision e
            JOIN pelicula p ON e.id_pelicula = p.id_pelicula
        WHERE
            p.duracion_min > 150
    );

COMMIT;

UPDATE pelicula p
SET
    p.genero = 'Neo-noir'
WHERE
    p.titulo = 'Pulp Fiction';

COMMIT;

